# ── Claude (clasificación con IA) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Airtable (base de datos central) ───────────────────────────
AIRTABLE_API_KEY=pat_...
AIRTABLE_BASE_ID=app...
AIRTABLE_TABLE_EMAILS=Emails
AIRTABLE_TABLE_MEETINGS=Meetings
AIRTABLE_TABLE_CLIENTS=GO Estudio Clientes Consolidados
AIRTABLE_TABLE_TEAM=Team

# ── Gmail (OAuth2 - ver README paso a paso) ────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...
GMAIL_QUERY=newer_than:1d

# ── Fathom ──────────────────────────────────────────────────────
FATHOM_API_KEY=...

# ── API del dashboard ───────────────────────────────────────────
# Clave simple que el dashboard.html manda en el header x-api-key
DASHBOARD_API_KEY=elegir-una-clave-larga-y-secreta

# ── Cron ─────────────────────────────────────────────────────────
# Cada cuánto revisa emails/reuniones nuevas (formato cron). Default: cada 15 min
POLL_CRON=*/15 * * * *

PORT=3000
